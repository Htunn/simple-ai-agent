# =============================================================================
# Simple AI Agent — Environment Template
# cp .env.example .env  — then fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Bot Tokens (GitHub required; at least one chat channel required) ---------
GITHUB_TOKEN=ghp_your_fine_grained_token_here

TELEGRAM_TOKEN=your_telegram_bot_token_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# --- Cloudflare Tunnel (optional) --------------------------------------------
# Required only if using the cloudflared service in docker-compose.
# Create a tunnel at https://one.dash.cloudflare.com and paste the token here.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# --- Database -----------------------------------------------------------------
# Docker Compose (default):
DATABASE_URL=postgresql+asyncpg://aiagent:aiagent_password@postgres:5432/aiagent
# Local dev override:
# DATABASE_URL=postgresql+asyncpg://aiagent:aiagent_password@localhost:5432/aiagent

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Local dev override:
# REDIS_URL=redis://localhost:6379/0

# --- Application --------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- AI Models ----------------------------------------------------------------
DEFAULT_MODEL=gpt-4

# --- MCP Configuration --------------------------------------------------------
MCP_CONFIG_PATH=.mcp-config.json

# --- Kubernetes ---------------------------------------------------------------
KUBECONFIG=/app/.kube/config
K8S_CONTEXT=

# --- Session ------------------------------------------------------------------
SESSION_TTL_SECONDS=3600

# --- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# --- AIOps — Watch-Loop -------------------------------------------------------
K8S_WATCHLOOP_ENABLED=true
K8S_WATCHLOOP_INTERVAL=30

# --- AIOps — Remediation ------------------------------------------------------
AUTO_REMEDIATION_ENABLED=false
# Format: telegram:<chat_id>  |  slack:<channel_id>
AIOPS_NOTIFICATION_CHANNEL=

# --- AIOps — Approval Gate ----------------------------------------------------
APPROVAL_TIMEOUT_SECONDS=300

# --- Webhook Security --------------------------------------------------------
# Telegram: set this and pass as secret_token to setWebhook to authenticate inbound requests
TELEGRAM_WEBHOOK_SECRET=
# Alertmanager: HMAC secret for X-Alertmanager-Secret header validation
ALERTMANAGER_WEBHOOK_SECRET=

# --- Observability ------------------------------------------------------------
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=

# --- OpenTelemetry Tracing ----------------------------------------------------
# Set OTEL_ENABLED=true and start the jaeger service to collect distributed traces.
# Jaeger UI: http://localhost:16686
OTEL_ENABLED=false
OTEL_SERVICE_NAME=simple-ai-agent
OTLP_ENDPOINT=http://jaeger:4317
OTEL_SAMPLE_RATE=1.0
